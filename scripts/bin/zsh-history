#!/usr/bin/env bash
# Standalone helper for zsh per-process / global history (used by fzf binds).
# Functions can't be exported to zsh subshells, so the logic lives here on $PATH.
#
# Stored line format: timestamp<TAB>pwd<TAB>command
# Output line format (for fzf): display<TAB>command   (column 2 = raw command)

set -u

HISTDIR="$HOME/.zsh_history_dir"

# Build the fzf display line. Input to this awk:  command<TAB>timestamp<TAB>pwd
# Output:  <display>\t<raw command>
#   - display field 1 is shown by fzf (--with-nth=1, --ansi)
#   - field 2 is the raw command, used for copy / run / delete (no ANSI)
# The command column is a FIXED width so the path/time columns line up on every
# row; commands longer than the column are truncated with an ellipsis (the raw
# command in field 2 is untouched). path and time are dimmed (ANSI 90).
_hist_format() {
    # Width source priority: COLUMNS (exported by the zle wrapper for the initial
    # list) -> FZF_COLUMNS (set by fzf inside reload subshells) -> tput -> 80.
    # tput is unreliable here because stdout is a pipe, so it is only a last resort.
    local cols
    for cols in "${COLUMNS:-}" "${FZF_COLUMNS:-}" "$(tput cols 2>/dev/null)" 80; do
        [ -n "$cols" ] && [ "$cols" != "0" ] && break
    done
    awk -F'\t' -v cols="$cols" '
    BEGIN {
        dim  = "\033[90m"; rst = "\033[0m"
        gap   = 2                      # spaces between columns
        timew = 19                     # YYYY-MM-DD HH:MM:SS
        # path gets a slice of the remaining width; command fills the rest so the
        # whole terminal width is used. time is right-aligned at the far edge.
        avail = cols - timew - gap*2
        if (avail < 30) avail = 30
        pathw = int(avail * 0.30)
        if (pathw < 12) pathw = 12
        cmdw  = avail - pathw
        if (cmdw < 10) cmdw = 10
    }
    function fit(s, w,   r) {
        if (length(s) > w) return substr(s, 1, w - 1) "…"
        r = s
        while (length(r) < w) r = r " "
        return r
    }
    {
        raw = $1; time = $2; path = $3
        # plain padding first (so ANSI codes do not skew widths), then color
        printf "%s  %s%s  %s%s\t%s\n", fit(raw, cmdw), dim, fit(path, pathw), time, rst, raw
    }'
}

# Dedup by command keeping the NEWEST occurrence. A single awk pass keeps, per
# command, the latest timestamp+pwd in a hash (no full sort); then one sort by
# timestamp for display. Stored line is  timestamp<TAB>pwd<TAB>command.
# $nopath=1 replaces the path column with "...".
_dedup_newest() {
    local nopath="$1"
    awk -F'\t' -v nopath="$nopath" '
        NF>=3 && $1 >= ts[$3] { ts[$3]=$1; pw[$3]=$2 }
        END { for (c in ts) print c"\t"ts[c]"\t"(nopath=="1" ? "..." : pw[c]) }
    ' | sort -t$'\t' -k2,2
}

list_process() {
    local pid="$1" nopath="$2"
    cat "$HISTDIR/pid_$pid" 2>/dev/null \
        | _dedup_newest "$nopath" \
        | _hist_format
}

list_global() {
    local nopath="$1"
    cat "$HISTDIR"/pid_* 2>/dev/null \
        | _dedup_newest "$nopath" \
        | _hist_format
}

# Remove every line whose command field (field 3) exactly equals one of the
# given entries, in a single awk pass. Entries are passed to awk via a NUL-joined
# env var so any character (spaces, tabs-in-cmd are impossible since field is
# tab-delimited, quotes, $) is handled literally.
# Note: grep/awk-filter can empty a file; never gate `mv` on exit status.
_strip_entries() {
    local file="$1"; shift
    [ -e "$file" ] || return 0
    local tmpfile
    tmpfile=$(mktemp)
    # Join entries with newline into ZH_DEL for awk to read as a set.
    local joined="" e
    for e in "$@"; do joined+="$e"$'\n'; done
    ZH_DEL="$joined" awk -F'\t' '
        BEGIN { n=split(ENVIRON["ZH_DEL"], a, "\n"); for(i=1;i<=n;i++) if(a[i]!="") del[a[i]]=1 }
        !($3 in del)
    ' "$file" > "$tmpfile"
    mv "$tmpfile" "$file"
}

delete_process() {
    local pid="$1"; shift
    _strip_entries "$HISTDIR/pid_$pid" "$@"
}

delete_global() {
    # Find files containing ANY of the entries as a whole command field, then
    # strip all entries from each in one pass. rg over all files is ~0.01s;
    # rewriting all (3000+) files unconditionally would be ~11s. Anchoring as
    # \t<entry>$ matches the whole command field so 'ls' won't match 'ls -la'.
    [ "$#" -gt 0 ] || return 0
    local e esc alt=""
    for e in "$@"; do
        esc=$(printf '%s' "$e" | sed 's/[][\\.^$*+?(){}|/]/\\&/g')
        [ -n "$alt" ] && alt+="|"
        alt+="$esc"
    done
    rg -l --no-config -- "\t($alt)\$" "$HISTDIR" -g 'pid_[0-9]*' 2>/dev/null | while IFS= read -r file; do
        _strip_entries "$file" "$@"
    done
}

cmd="${1:-}"
shift || true
case "$cmd" in
    list-process)
        nopath=0; [ "${1:-}" = "--no-path" ] && { nopath=1; shift; }
        list_process "${1:-$$}" "$nopath"
        ;;
    list-global)
        nopath=0; [ "${1:-}" = "--no-path" ] && { nopath=1; shift; }
        list_global "$nopath"
        ;;
    delete-process)
        pid="$1"; shift
        delete_process "$pid" "$@"
        ;;
    delete-global)
        delete_global "$@"
        ;;
    *)
        echo "usage: zsh-history {list-process [--no-path] [pid]|list-global [--no-path]|delete-process <pid> <entry>...|delete-global <entry>...}" >&2
        exit 2
        ;;
esac
